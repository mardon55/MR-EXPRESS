modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd 'mr express/backend' && python run_api.py & sleep 3 && cd 'mr express/frontend' && npm run dev -- --port 5000 --host 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Admin Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd 'mr express admin/backend' && python run_api.py"
waitForPort = 8008

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd 'mr express/backend' && python run_bot.py"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd 'mr express admin/frontend' && npm run dev"
waitForPort = 5173

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8008
externalPort = 8008

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd 'mr express admin/backend' && uvicorn app.main:app --host 0.0.0.0 --port 8008 & cd 'mr express/backend' && uvicorn app.main:app --host 0.0.0.0 --port 8000 & cd 'mr express admin/frontend' && npm run dev -- --port 5000 --host 0.0.0.0"]
build = ["bash", "-c", "cd 'mr express admin/frontend' && npm run build && cd '../../mr express/frontend' && npm run build"]

[userenv]

[userenv.shared]
WEBAPP_URL = "https://db47bcb2-6d2b-4e2d-88c6-4316b492e76a-00-9cglao4dfizr.pike.replit.dev"
